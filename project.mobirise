          "_name": "article07",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article07\" group=\"Article\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n  <mbr-parameters>\n    <header>Size</header>\n    <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\" checked>\n    <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n    <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n    <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n    <input type=\"range\" inline title=\"Content Width\" name=\"contentWidth\" min=\"8\" max=\"12\" step=\"1\" value=\"12\">\n    <header>Show/Hide</header>\n    <input type=\"checkbox\" title=\"Title\" name=\"showTitle\">\n    <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n    <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n    <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n    <input type=\"color\" title=\"Wrap Bg\" name=\"wrapBgColor\" value=\"#ffffff\">\n    <header>Background</header>\n    <fieldset type=\"background\" name=\"bg\" parallax>\n      <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\" parallax>\n      <input type=\"color\" title=\"Color\" value=\"#edefeb\" selected>\n      <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n    </fieldset>\n    <header condition=\"bg.type === 'video'\">Fallback Image</header>\n    <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n    <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n    <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n    <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.3\" condition=\"overlay && bg.type !== 'color'\">\n  </mbr-parameters>\n\n  <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n  <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n  <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n    <div class=\"row justify-content-center\">\n      <div class=\"card col-md-12 col-lg-{{contentWidth}}\">\n        <div class=\"card-wrapper\">\n          <h3 class=\"card-title mbr-fonts-style mbr-white mt-3 mb-4\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .card-box\">\n            <b>Delivery Terms:</b>\n          </h3>\n          <div class=\"row card-box align-left\">\n            \n            <div class=\"item features-without-image col-12 active\">\n              <div class=\"item-wrapper\">\n                <h4 class=\"mbr-section-subtitle mbr-fonts-style mb-3\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-5\"><b>Human Resources/ Admin Jobs</b></h4>\n                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\"><a href=\"https://iagjme.fa.ocs.oraclecloud.com/hcmUI/CandidateExperience/en/sites/CX_1005/job/1485/?utm_medium=jobshare&utm_source=External+Job+Share\" class=\"text-primary\" target=\"_blank\">Payroll Support Administrator (T&amp;A) -&nbsp;Hollywoodbets, Kwazulu Natal</a><br><a href=\"https://careers.ey.com/ey/job/Johannesburg-Human-Capital-Consultant-GT-2146/1372989833/\" class=\"text-primary\" target=\"_blank\">Human Capital Consultant - EY, Johannesburg</a><br><a href=\"https://iagjme.fa.ocs.oraclecloud.com/hcmUI/CandidateExperience/en/sites/CX_1005/job/1535/?utm_medium=jobshare&utm_source=External+Job+Share\" class=\"text-primary\" target=\"_blank\">Receptionist - Hollywoodbets, Kwazulu Natal</a><a href=\"https://iagjme.fa.ocs.oraclecloud.com/hcmUI/CandidateExperience/en/sites/CX_1005/job/1485/?utm_medium=jobshare&utm_source=External+Job+Share\" class=\"text-primary\" target=\"_blank\"><br></a><a href=\"https://myfocus.psg.co.za/CareerFocus/Vacancy/HRF_VACANCY_SEARCH_CAREERS_BLOCK.aspx\" class=\"text-primary\" target=\"_blank\">Administrative Assistant - PSG,&nbsp;&nbsp; Jeffreys Bay, Eastern Cape</a><br><a href=\"https://fa-etyi-saasfaprod1.fa.ocs.oraclecloud.com/hcmUI/CandidateExperience/en/sites/MrPriceGroupCareers/job/4141/?utm_medium=jobshare&utm_source=External+Job+Share\" class=\"text-primary\" target=\"_blank\">Executive Associate - Mr Price Group,&nbsp;Cape Town</a><br><a href=\"https://picknpay.wd3.myworkdayjobs.com/en-US/PNP_Careers/job/Online-Administrator_JR105168-1\" class=\"text-primary\" target=\"_blank\">Online Administrator - Pick n Pay, Cape Town</a><br><a href=\"https://ccba.erecruit.co/candidateapp/Jobs/View/CCB260225-5\" class=\"text-primary\" target=\"_blank\">Unemployed Learnership: Human Resources (Bonded for people with disabilities)Coca Cola, Johannesburg</a><a href=\"https://iagjme.fa.ocs.oraclecloud.com/hcmUI/CandidateExperience/en/sites/CX_1005/job/1485/?utm_medium=jobshare&utm_source=External+Job+Share\" class=\"text-primary\" target=\"_blank\"><br></a></p>\n              </div>\n            </div>\n            \n            <div class=\"item features-without-image col-12\">\n              <div class=\"item-wrapper\">\n                <h4 class=\"mbr-section-subtitle mbr-fonts-style mb-3\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-5\"><b>Finance Jobs</b></h4>\n                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\"><a href=\"https://iagjme.fa.ocs.oraclecloud.com/hcmUI/CandidateExperience/en/sites/CX_1005/job/1490/?utm_medium=jobshare&utm_source=External+Job+Share\" class=\"text-primary\" target=\"_blank\">Junior Internal Auditor - Hollywoodbets, Kwazulu Natal</a></p>\n              </div>\n            </div><div class=\"item features-without-image col-12\">\n              <div class=\"item-wrapper\">\n                <h4 class=\"mbr-section-subtitle mbr-fonts-style mb-3\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-5\"><b>Retail &amp; Customer Service Jobs&nbsp;</b></h4>\n                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\"><a href=\"https://bidvestbank.breezy.hr/p/00bb22cd1768-consultant-business-service-centre-kzn\" class=\"text-primary\" target=\"_blank\">Consultant: Business Service Centre - Bidvest Bank,&nbsp;KwaZulu Natal</a></p>\n              </div>\n            </div><div class=\"item features-without-image col-12\">\n              <div class=\"item-wrapper\">\n                <h4 class=\"mbr-section-subtitle mbr-fonts-style mb-3\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-5\"><b>Information Technology/ Tech Jobs</b></h4>\n                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\"><a href=\"https://www.accenture.com/za-en/careers/jobdetails?id=14210769_en&title=Business+Analyst\" class=\"text-primary\" target=\"_blank\">Business Analyst - Accenture, Midrand&nbsp;</a><br><a href=\"https://careers.ey.com/ey/job/Johannesburg-Junior-Software-Developer-GT-2146/1373028233/?utm_campaign=google_jobs_apply&utm_source=google_jobs_apply&utm_medium=organic\" class=\"text-primary\" target=\"_blank\">Junior Software Developer - EY, Johannesburg</a><a href=\"https://www.accenture.com/za-en/careers/jobdetails?id=14210769_en&title=Business+Analyst\" class=\"text-primary\" target=\"_blank\"><br></a></p>\n              </div>\n            </div><div class=\"item features-without-image col-12\">\n              <div class=\"item-wrapper\">\n                <h4 class=\"mbr-section-subtitle mbr-fonts-style mb-3\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-5\"><b>Other &amp; Remote Jobs</b></h4>\n                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\"><a href=\"https://fa-etyi-saasfaprod1.fa.ocs.oraclecloud.com/hcmUI/CandidateExperience/en/sites/MrPriceGroupCareers/job/3968/?utm_medium=jobshare&utm_source=External+Job+Share\" class=\"text-primary\" target=\"_blank\">Workplace Experience Program - Buying Stream (Apparel) - Mr Price Group,&nbsp;Durban, Kwazulu Natal</a><br><a href=\"https://bidvestbank.breezy.hr/p/706d0ef20b4a-forex-sales-co-ordinator-6-months-ftc-musina\" class=\"text-primary\" target=\"_blank\">Forex Sales Co-Ordinator - Bidvest Bank - 6 Months FTC, Musina, Limpopo</a><br><a href=\"https://clover.erecruit.co/candidateapp/Jobs/View/CLO260318-1\" class=\"text-primary\" target=\"_blank\">Handyman - Clover,&nbsp;\tQueensburgh,&nbsp;KwaZulu-Natal</a><a href=\"https://bidvestbank.breezy.hr/p/706d0ef20b4a-forex-sales-co-ordinator-6-months-ftc-musina\" class=\"text-primary\" target=\"_blank\"><br></a><br><a href=\"https://bidvestbank.breezy.hr/p/706d0ef20b4a-forex-sales-co-ordinator-6-months-ftc-musina\" class=\"text-primary\" target=\"_blank\"><br></a><a href=\"https://fa-etyi-saasfaprod1.fa.ocs.oraclecloud.com/hcmUI/CandidateExperience/en/sites/MrPriceGroupCareers/job/3968/?utm_medium=jobshare&utm_source=External+Job+Share\" class=\"text-primary\" target=\"_blank\"><br></a><a href=\"https://job-boards.greenhouse.io/hyperiondev/jobs/8296819002\" class=\"text-primary\" target=\"_blank\"><br></a></p>\n              </div>\n            </div>\n          </div>\n          <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n            <a class=\"btn btn-primary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">Start Now</a>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>",
