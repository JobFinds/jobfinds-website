    "page30.html": {
      "settings": {
        "title": "Relocating to South Africa: Your Ultimate Guide to Living and Working in the Rainbow Nation",
        "order": "4",
        "meta_descr": "Planning to move to South Africa? This guide covers working, living, visas, and job opportunities for locals and internationals."
      },
      "components": [
        {
          "alias": false,
          "_styles": {
            "z-index": "1000",
            "width": "100%",
